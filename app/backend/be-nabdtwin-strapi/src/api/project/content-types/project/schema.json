{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Project entity"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "organization": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::organization.organization",
      "inversedBy": "projects"
    },
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "description": {
      "type": "text"
    },
    "department": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::department.department",
      "inversedBy": "projects"
    },
    "team": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::team.team",
      "inversedBy": "projects"
    },
    "projectStatus": {
      "type": "enumeration",
      "columnName": "status",
      "enum": ["planning", "active", "on-hold", "completed", "cancelled"]
    },
    "priority": {
      "type": "enumeration",
      "enum": ["low", "medium", "high", "critical"]
    },
    "startDate": {
      "type": "date"
    },
    "endDate": {
      "type": "date"
    },
    "budget": {
      "type": "decimal"
    },
    "actualCost": {
      "type": "decimal"
    },
    "progressPercentage": {
      "type": "decimal",
      "min": 0,
      "max": 100
    },
    "createdBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::employee.employee",
      "inversedBy": "createdProjects"
    },
    "tasks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::task.task",
      "mappedBy": "project"
    }
  }
}

{
  "kind": "collectionType",
  "collectionName": "organizations",
  "info": {
    "singularName": "organization",
    "pluralName": "organizations",
    "displayName": "Organization",
    "description": "Main organization entity"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 255
    },
    "description": {
      "type": "text"
    },
    "industry": {
      "type": "string",
      "maxLength": 100
    },
    "logoUrl": {
      "type": "text"
    },
    "branches": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::branch.branch",
      "mappedBy": "organization"
    },
    "departments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::department.department",
      "mappedBy": "organization"
    },
    "employees": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::employee.employee",
      "mappedBy": "organization"
    },
    "projects": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::project.project",
      "mappedBy": "organization"
    },
    "reports": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::report.report",
      "mappedBy": "organization"
    },
    "alerts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::alert.alert",
      "mappedBy": "organization"
    },
    "insights": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::insight.insight",
      "mappedBy": "organization"
    }
  }
}

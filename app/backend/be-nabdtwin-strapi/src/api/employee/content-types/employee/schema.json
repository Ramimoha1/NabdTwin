{
  "kind": "collectionType",
  "collectionName": "employees",
  "info": {
    "singularName": "employee",
    "pluralName": "employees",
    "displayName": "Employee",
    "description": "Schema for the employees table. Relationships must be added manually."
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "attributes": {
    "organization_id": {
      "type": "string"
    },
    "employee_number": {
      "type": "string",
      "maxLength": 50,
      "unique": true
    },
    "first_name": {
      "type": "string",
      "maxLength": 100,
      "required": true
    },
    "last_name": {
      "type": "string",
      "maxLength": 100,
      "required": true
    },
    "email": {
      "type": "string",
      "maxLength": 255,
      "required": true,
      "unique": true
    },
    "phone": {
      "type": "string",
      "maxLength": 50
    },
    "date_of_birth": {
      "type": "date"
    },
    "gender": {
      "type": "enumeration",
      "maxLength": 20,
      "enum": [
        "male",
        "female",
        "other",
        "prefer_not_to_say"
      ]
    },
    "department_id": {
      "type": "string"
    },
    "team_id": {
      "type": "string"
    },
    "branch_id": {
      "type": "string"
    },
    "workspace_id": {
      "type": "string"
    },
    "supervisor_id": {
      "type": "string"
    },
    "employment_status": {
      "type": "enumeration",
      "maxLength": 20,
      "enum": [
        "active",
        "inactive",
        "on-leave",
        "terminated"
      ],
      "default": "active"
    },
    "hire_date": {
      "type": "date"
    },
    "termination_date": {
      "type": "date"
    },
    "currency": {
      "type": "string",
      "maxLength": 3,
      "default": "USD"
    },
    "position_z": {
      "type": "decimal",
      "precision": 10,
      "scale": 2
    },
    "avatar_url": {
      "type": "text"
    }
  }
}
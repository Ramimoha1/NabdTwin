{
  "kind": "collectionType",
  "collectionName": "tasks",
  "info": {
    "singularName": "task",
    "pluralName": "tasks",
    "displayName": "Task",
    "description": "Schema for the tasks table. Relationships must be added manually."
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "attributes": {
    "project_id": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "maxLength": 255,
      "required": true
    },
    "description": {
      "type": "text"
    },
    "assigned_to": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "maxLength": 50,
      "enum": [
        "todo",
        "in-progress",
        "review",
        "completed",
        "cancelled"
      ]
    },
    "priority": {
      "type": "enumeration",
      "maxLength": 20,
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "due_date": {
      "type": "date"
    },
    "completed_date": {
      "type": "date"
    },
    "estimated_hours": {
      "type": "decimal",
      "precision": 6,
      "scale": 2
    },
    "actual_hours": {
      "type": "decimal",
      "precision": 6,
      "scale": 2
    }
  }
}
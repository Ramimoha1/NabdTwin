{
  "kind": "collectionType",
  "collectionName": "up_users",
  "info": {
    "name": "user",
    "description": "",
    "singularName": "user",
    "pluralName": "users",
    "displayName": "User"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "username": {
      "type": "string",
      "minLength": 3,
      "unique": true,
      "configurable": false,
      "required": true
    },
    "email": {
      "type": "email",
      "minLength": 6,
      "configurable": false,
      "required": true
    },
    "provider": {
      "type": "string",
      "configurable": false
    },
    "password": {
      "type": "password",
      "minLength": 6,
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "resetPasswordToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "resetPasswordExpires": {
      "type": "datetime",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmationToken": {
      "type": "string",
      "configurable": false,
      "private": true,
      "searchable": false
    },
    "confirmed": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "blocked": {
      "type": "boolean",
      "default": false,
      "configurable": false
    },
    "role": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.role",
      "inversedBy": "users",
      "configurable": false
    },
    "type": {
      "type": "enumeration",
      "required": true,
      "default": "normal",
      "enum": [
        "admin",
        "normal"
      ]
    },
    "employee": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::employee.employee",
      "mappedBy": "user"
    },
    "userBranchPermissions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-branch-permission.user-branch-permission",
      "mappedBy": "user"
    },
    "userFeaturePermissions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-feature-permission.user-feature-permission",
      "mappedBy": "user"
    },
    "userAlertStatuses": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-alert-status.user-alert-status",
      "mappedBy": "user"
    },
    "dashboards": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::dashboard.dashboard",
      "mappedBy": "user"
    },
    "advisory_logs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::advisory-log.advisory-log",
      "mappedBy": "user"
    }
  }
}

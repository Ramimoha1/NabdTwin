{
  "kind": "collectionType",
  "collectionName": "users",
  "info": {
    "singularName": "user",
    "pluralName": "users",
    "displayName": "User",
    "description": "Schema for the users table. Relationships must be added manually."
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "attributes": {
    "employee_id": {
      "type": "string"
    },
    "username": {
      "type": "string",
      "maxLength": 100,
      "required": true,
      "unique": true
    },
    "email": {
      "type": "string",
      "maxLength": 255,
      "required": true,
      "unique": true
    },
    "password_hash": {
      "type": "string",
      "maxLength": 255,
      "required": true
    },
    "role": {
      "type": "enumeration",
      "maxLength": 20,
      "enum": [
        "admin",
        "normal"
      ],
      "required": true
    },
    "is_active": {
      "type": "boolean"
    },
    "last_login": {
      "type": "datetime"
    }
  }
}
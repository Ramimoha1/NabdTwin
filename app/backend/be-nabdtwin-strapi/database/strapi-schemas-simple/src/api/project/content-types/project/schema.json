{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Schema for the projects table. Relationships must be added manually."
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "attributes": {
    "organization_id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "maxLength": 255,
      "required": true
    },
    "description": {
      "type": "text"
    },
    "department_id": {
      "type": "string"
    },
    "team_id": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "maxLength": 50,
      "enum": [
        "planning",
        "active",
        "on-hold",
        "completed",
        "cancelled"
      ]
    },
    "priority": {
      "type": "enumeration",
      "maxLength": 20,
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "start_date": {
      "type": "date"
    },
    "end_date": {
      "type": "date"
    },
    "budget": {
      "type": "decimal",
      "precision": 15,
      "scale": 2
    },
    "actual_cost": {
      "type": "decimal",
      "precision": 15,
      "scale": 2
    },
    "progress_percentage": {
      "type": "decimal",
      "precision": 5,
      "scale": 2
    },
    "created_by": {
      "type": "string"
    }
  }
}
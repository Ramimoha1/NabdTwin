{
  "kind": "collectionType",
  "collectionName": "attendance_records",
  "info": {
    "singularName": "attendance-record",
    "pluralName": "attendance-records",
    "displayName": "Attendance Record",
    "description": "Schema for the attendance_records table. Relationships must be added manually."
  },
  "options": {
    "draftAndPublish": false,
    "timestamps": true
  },
  "attributes": {
    "employee_id": {
      "type": "string"
    },
    "date": {
      "type": "date"
    },
    "check_in_time": {
      "type": "datetime"
    },
    "check_out_time": {
      "type": "datetime"
    },
    "status": {
      "type": "enumeration",
      "maxLength": 20,
      "enum": [
        "present",
        "absent",
        "late",
        "on-leave",
        "sick-leave",
        "holiday"
      ]
    },
    "hours_worked": {
      "type": "decimal",
      "precision": 5,
      "scale": 2
    },
    "notes": {
      "type": "text"
    }
  }
}